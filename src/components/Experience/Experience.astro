---
import { dataExperience } from "../../constants";

const experienceCards = dataExperience.map((item) => ({
  ...item,
  summary: item.responsibilites.slice(0, 3).join(" "),
}));
---

<section id="experience" class="section-block scroll-mt-32">
  <div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
    <div class="surface-card p-6 md:sticky md:top-28 md:p-8">
      <span class="section-kicker">Experience</span>
      <h2 class="section-heading mt-6">Experience across product, agency, and founder-led delivery.</h2>
      <p class="mt-5 text-sm leading-7 text-[var(--muted)] md:text-base md:leading-8">
        Each role strengthened a different part of my practice, from backend architecture and fullstack execution to
        technical ownership and delivery across real-world products.
      </p>
    </div>

    <div class="grid gap-5">
      {
        experienceCards.map((experience, index) => (
          <article
            class="overflow-hidden rounded-[32px] border p-6 text-white shadow-[0_24px_60px_rgba(15,17,19,0.12)] md:p-8"
            style={`background: radial-gradient(circle at top right, ${experience.second_color} 0%, ${experience.first_color} 55%); border-color: ${experience.border_color};`}
          >
            <div class="flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
              <div class="flex items-start gap-4">
                <span class="inline-flex h-12 w-12 items-center justify-center rounded-[18px] bg-white/10 text-sm font-extrabold tracking-[0.18em] text-white/86">
                  0{index + 1}
                </span>
                <div>
                  <p class="text-[0.74rem] font-bold uppercase tracking-[0.18em] text-white/58">{experience.date}</p>
                  <h3 class="mt-2 text-[1.9rem] font-bold tracking-[-0.05em]">{experience.name}</h3>
                  <p class="mt-2 text-sm font-semibold text-white/76">{experience.description}</p>
                </div>
              </div>

              <div class="flex items-center gap-3 md:justify-end">
                <div class="flex h-14 min-w-[72px] items-center justify-center rounded-[20px] border border-white/10 bg-white/8 px-4">
                  <img src={experience.logo_url} alt={experience.name} class="max-h-9 w-auto object-contain" loading="lazy" decoding="async" />
                </div>
                <span class="glass-badge rounded-full px-4 py-2 text-xs font-bold uppercase tracking-[0.16em] text-white/92">
                  {experience.position}
                </span>
              </div>
            </div>

            <p class="mt-6 text-justify text-sm leading-8 text-white/82 md:text-base">
              {experience.summary}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
