---

<section id="projects" class="section-block scroll-mt-32">
  <div class="surface-card p-6 md:p-10">
    <div class="grid gap-8 lg:grid-cols-[0.7fr_1.3fr] lg:items-end">
      <div class="max-w-sm">
        <span class="section-kicker">Projects</span>
        <h2 class="section-heading mt-6">Project archive.</h2>
      </div>

      <p
        class="max-w-3xl text-sm leading-7 text-[var(--muted)] md:text-base md:leading-8"
      >
        A focused archive of shipped work across internal systems, dashboards,
        public-service products, and operational platforms. The first five
        projects stay in view, with the rest available below.
      </p>
    </div>

    <div class="project-list mt-8">
      {
        featuredProjects.map((project, index) => (
          <article class:list={["project-row group"]}>
            <div class="project-row-copy">
              <div class="project-row-head">
                <div class="project-row-index">
                  {(index + 1).toString().padStart(2, "0")}
                </div>
                <div class="project-row-heading">
                  <p class="project-row-category">{project.category}</p>
                  <div class="project-row-title-wrap">
                    <h3 class="project-row-title">{project.title}</h3>
                  </div>
                </div>
              </div>

              <p class="project-row-summary">{project.summary}</p>

              <div class="project-row-tags">
                {project.stack.map((item) => (
                  <span class="glass-badge project-row-tag">{item}</span>
                ))}
              </div>
            </div>

            <div class="project-preview" aria-hidden="true">
              <div class="project-preview-frame">
                <img
                  src={project.image}
                  alt={project.title}
                  class="project-preview-image"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <details class="project-more mt-8">
      <summary class="glass-badge project-more-trigger">More projects</summary>

      <div class="project-list project-list-more">
        {
          moreProjects.map((project, index) => (
            <article class="project-row group">
              <div class="project-row-copy">
                <div class="project-row-head">
                  <div class="project-row-index">
                    {(index + 6).toString().padStart(2, "0")}
                  </div>
                  <div>
                    <p class="project-row-category">{project.category}</p>
                    <h3 class="project-row-title">{project.title}</h3>
                  </div>
                </div>

                <p class="project-row-summary">{project.summary}</p>

                <div class="project-row-tags">
                  {project.stack.map((item) => (
                    <span class="glass-badge project-row-tag">{item}</span>
                  ))}
                </div>
              </div>

              <div class="project-preview" aria-hidden="true">
                <div class="project-preview-frame">
                  <img
                    src={project.image}
                    alt={project.title}
                    class="project-preview-image"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </details>
  </div>
</section>

<style>
  .project-list {
    display: grid;
    gap: 0.95rem;
  }

  .project-row {
    position: relative;
    overflow: visible;
    margin-top: 0;
    margin-bottom: 0;
    width: 100%;
    min-height: 236px;
    border: 1px solid rgba(17, 19, 21, 0.08);
    border-radius: 30px;
    background: rgba(255, 251, 245, 0.72);
    box-shadow: 0 12px 30px rgba(15, 17, 19, 0.03);
    transition: border-color 220ms ease, box-shadow 220ms ease,
      transform 220ms ease;
  }

  .project-row:hover {
    border-color: rgba(94, 75, 245, 0.18);
    box-shadow: 0 18px 40px rgba(15, 17, 19, 0.08);
    transform: translateY(-2px);
  }

  .project-row-copy {
    position: relative;
    z-index: 2;
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.5rem;
  }

  .project-row-head {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .project-row-heading {
    min-width: 0;
  }

  .project-row-index {
    display: inline-flex;
    height: 44px;
    width: 44px;
    flex: none;
    align-items: center;
    justify-content: center;
    border-radius: 16px;
    background: rgba(94, 75, 245, 0.07);
    font-size: 0.9rem;
    font-weight: 700;
    color: rgb(94, 75, 245);
    transition: background-color 220ms ease, color 220ms ease;
  }

  .project-row-category {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 220ms ease;
  }

  .project-row-title {
    margin-top: 0.8rem;
    max-width: 18ch;
    font-size: 1.9rem;
    font-weight: 700;
    letter-spacing: -0.06em;
    color: #111315;
    transition: color 220ms ease;
  }

  .project-row-title-wrap {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.7rem;
  }

  .project-row-summary {
    max-width: none;
    font-size: 0.98rem;
    line-height: 1.9;
    color: var(--muted);
    transition: color 220ms ease;
  }

  .project-row-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .project-row-tag {
    padding: 0.5rem 0.8rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    color: #2d3238;
    transition: color 220ms ease, background-color 220ms ease,
      border-color 220ms ease;
  }

  .project-preview {
    pointer-events: none;
    position: absolute;
    top: 50%;
    right: 1.4rem;
    z-index: 3;
    width: min(470px, 40%);
    opacity: 0;
    transform: translate(24px, -50%) rotate(4deg) scale(0.96);
    transition: opacity 260ms ease, transform 260ms ease;
  }

  .project-preview-frame {
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.78);
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.78);
    padding: 0.6rem;
    box-shadow: 0 24px 60px rgba(15, 17, 19, 0.12);
    backdrop-filter: blur(14px);
  }

  .project-preview-image {
    aspect-ratio: 16 / 11;
    width: 100%;
    border-radius: 18px;
    object-fit: cover;
    object-position: top;
  }

  .project-row:hover .project-preview {
    opacity: 1;
    transform: translate(0, -50%) rotate(0) scale(1);
  }

  .project-row:hover .project-row-index {
    background: rgba(94, 75, 245, 0.14);
  }

  .project-private-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(17, 19, 21, 0.1);
    background: rgba(17, 19, 21, 0.05);
    padding: 0.38rem 0.75rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #3e444a;
  }

  .project-row.is-private {
    background: radial-gradient(
        circle at right top,
        rgba(94, 75, 245, 0.08),
        transparent 32%
      ),
      rgba(255, 251, 245, 0.74);
  }

  .project-more {
    margin-top: 2rem;
  }

  .project-more-trigger {
    display: inline-flex;
    cursor: pointer;
    list-style: none;
    border-radius: 999px;
    padding: 0.8rem 1rem;
    font-size: 0.84rem;
    font-weight: 700;
    color: rgb(94, 75, 245);
  }

  .project-more-trigger::-webkit-details-marker {
    display: none;
  }

  .project-list-more {
    margin-top: 1rem;
  }

  @media (min-width: 1024px) {
    .project-row-copy {
      width: 55%;
      max-width: 55%;
    }

    .project-preview {
      width: 40%;
    }
  }

  @media (max-width: 1023px) {
    .project-preview {
      display: none;
    }

    .project-list {
      gap: 0.75rem;
    }

    .project-row {
      min-height: auto;
      border-radius: 24px;
    }

    .project-row-copy {
      padding: 1rem;
      gap: 0.9rem;
    }

    .project-more {
      margin-top: 1rem;
    }
  }

  @media (max-width: 720px) {
    .project-row-title {
      margin-top: 0.55rem;
      font-size: 1.32rem;
    }

    .project-row-summary {
      font-size: 0.9rem;
      line-height: 1.72;
    }

    .project-row-title-wrap {
      align-items: flex-start;
    }

    .project-row-tag {
      padding: 0.4rem 0.65rem;
      font-size: 0.68rem;
    }
  }

  :global(html[data-theme="dark"]) .project-row {
    border-color: rgba(255, 255, 255, 0.08);
    background: rgba(20, 22, 28, 0.84);
    box-shadow: 0 18px 34px rgba(0, 0, 0, 0.18);
  }

  :global(html[data-theme="dark"]) .project-row-title {
    color: #f3eee7;
  }

  :global(html[data-theme="dark"]) .project-row-tag {
    color: #ede7df;
  }

  :global(html[data-theme="dark"]) .project-preview-frame {
    border-color: rgba(255, 255, 255, 0.1);
    background: rgba(20, 22, 28, 0.9);
  }

  :global(.theme-snapshot-overlay[data-snapshot-theme="light"]) .project-row-title {
    color: #111315;
  }

  :global(.theme-snapshot-overlay[data-snapshot-theme="light"]) .project-row-tag {
    color: rgb(94, 75, 245);
  }

  :global(.theme-snapshot-overlay[data-snapshot-theme="light"]) .project-preview-frame {
    border-color: rgba(17, 19, 21, 0.08);
    background: rgba(255, 251, 245, 0.74);
  }

  :global(.theme-snapshot-overlay[data-snapshot-theme="dark"]) .project-row {
    border-color: rgba(255, 255, 255, 0.08);
    background: rgba(20, 22, 28, 0.84);
    box-shadow: 0 18px 34px rgba(0, 0, 0, 0.18);
  }

  :global(.theme-snapshot-overlay[data-snapshot-theme="dark"]) .project-row-title {
    color: #f3eee7;
  }

  :global(.theme-snapshot-overlay[data-snapshot-theme="dark"]) .project-row-tag {
    color: #ede7df;
  }

  :global(.theme-snapshot-overlay[data-snapshot-theme="dark"]) .project-preview-frame {
    border-color: rgba(255, 255, 255, 0.1);
    background: rgba(20, 22, 28, 0.9);
  }
</style>
